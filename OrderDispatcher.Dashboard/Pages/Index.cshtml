@page
@using OrderDispatcher.Core.Constants
@using OrderDispatcher.Core.Sagas
@model OrderDispatcher.Dashboard.Pages.IndexModel
@{
    ViewData["Title"] = "System Dashboard";
}

<h1>Order Dispatcher Dashboard</h1>
<hr />

<p style="font-size: 1.1em;">
    <b>Total Orders:</b> @Model.TotalOrders |
    <b>Completed:</b> <span style="color: green;">@Model.CompletedOrders</span> |
    <b>Pending:</b> <span style="color: orange;">@Model.PendingOrders</span>
</p>

@if (Model.DeadLetterMessageCount > 0)
{
    <div style="color: red; border: 2px solid red; padding: 15px; margin-bottom: 20px; background-color: #ffe6e6;">
        <h3 style="margin-top: 0;">Alert: @Model.DeadLetterMessageCount failed message(s) in queue!</h3>

        <form method="post" asp-page-handler="ResendAll">
            <button type="submit" style="background-color: red; color: white; padding: 10px 15px; cursor: pointer; border: none; font-weight: bold;">
                ↻ Resend Failed Messages
            </button>
        </form>
    </div>
}

<h2>All System Orders</h2>

@if (Model.AllOrders.Any())
{
    <table border="1" cellpadding="8" style="border-collapse: collapse; width: 100%; text-align: left;">
        <tr style="background-color: #f2f2f2;">
            <th>Order ID</th>
            <th>Status</th>
            <th>Warehouse Doc</th>
            <th>Last Updated (UTC)</th>
            <th>Correlation ID</th>
        </tr>

        @foreach (var order in Model.AllOrders)
        {
            var statusColor = order.CurrentState switch
            {
                SagaStateNames.Final => "green",
                SagaStateNames.WaitingForOrder => "orange",
                SagaStateNames.WaitingForWarehouseDoc => "blue",
                _ => "gray"
            };

            <tr>
                <td><b>@order.OrderId</b></td>

                <td style="color: @statusColor; font-weight: bold;">
                    @order.CurrentState
                </td>

                <td>
                    @if (string.IsNullOrEmpty(order.WarehouseDocumentId))
                    {
                        <i style="color: gray;">Pending...</i>
                    }
                    else
                    {
                        @order.WarehouseDocumentId
                    }
                </td>
                <td>@order.UpdatedAt?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td><small style="color: gray;">@order.CorrelationId</small></td>
            </tr>
        }
    </table>
}
else
{
    <p><i>No orders have been processed yet.</i></p>
}

@section Scripts {
    <script>
        setTimeout(function () {
            window.location.reload();
        }, 5000);
    </script>
}